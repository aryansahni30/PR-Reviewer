# Required: Your NVIDIA API key
NVIDIA_API_KEY=nvapi-your-key-here

# Optional: GitHub Personal Access Token
# Without this, GitHub API rate limits to 60 req/hour (unauthenticated)
# With this, rate limits increase to 5000 req/hour
# Required for: private repos, posting comments
# Scopes needed: repo (for private repos), public_repo (for public repos)
GITHUB_TOKEN=ghp_your-token-here
